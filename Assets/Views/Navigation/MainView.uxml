    <ui:VisualElement name="MainView" class="menu-background-color" style="flex-grow: 1; padding-top: 200px; padding-bottom: 100px; padding-right: 400px; padding-left: 400px;">
        <ui:Label text="Title" name="GameNameLabel" class="h1 text-white-color" style="-unity-text-align: middle-center; height: 350px;"/>
        <ui:Label text="&lt; Press Any Button &gt;" name="PressAnyButtonLabel" class="h3 text-white-color button-text" style="-unity-text-align: upper-center; position: absolute; top: 738px; left: 749px;"/>
        <ui:VisualElement name="ButtonContainer" style="align-items: center; justify-content: space-evenly; flex-grow: 1;">
            <ui:Button name="PlayButton" text="Play&#10;" class="button button-text text-white-color"/>
            <ui:Button text="Settings" name="SettingButton" class="button button-text text-white-color"/>
            <ui:Button text="Exit" name="ExitButton" class="button button-text text-white-color" style="transition-timing-function: ease-in;"/>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
