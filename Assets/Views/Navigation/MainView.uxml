    <Style src="project://database/Assets/Views/Styles/Animation.uss?fileID=7433441132597879392&amp;guid=8d2330a3c35d3dd46989a0e3450695cf&amp;type=3#Animation"/>
    <Style src="project://database/Assets/Views/Styles/Typography.uss?fileID=7433441132597879392&amp;guid=6c7c6de22c85aed4692067f0b334d5b2&amp;type=3#Typography"/>
